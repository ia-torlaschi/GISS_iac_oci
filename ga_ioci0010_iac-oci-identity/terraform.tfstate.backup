          "schema_version": 0,
          "attributes": {
            "ETag": "0c189bcd0089c86b8869842d992e3eb229414e92",
            "compartment_id": "ocid1.compartment.oc19..aaaaaaaa43gu35rhrbtmirjlkxilrma3v5s2bqzhico4up6jvstnluiud3oa",
            "defined_tags": {
              "Oracle-Tags.CreatedBy": "default/jorge.e.torlaschi@accenture.com",
