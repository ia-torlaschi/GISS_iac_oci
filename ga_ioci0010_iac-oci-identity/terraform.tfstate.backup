              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-database-001', 'o-p-om2-id-common-001'/'99GISS.Cloud_DB_admin' to use cloud-vmclusters in compartment o-p-om2-cmp-land-001 where all{sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exadb-001')), request.permission != 'CLOUD_VM_CLUSTER_UPDATE_SSH_KEY', request.permission != 'CLOUD_VM_CLUSTER_UPDATE_CPU', request.permission != 'CLOUD_VM_CLUSTER_UPDATE_MEMORY', request.permission !='CLOUD_VM_CLUSTER_UPDATE_LOCAL_STORAGE', request.permission != 'CLOUD_VM_CLUSTER_UPDATE_FILE_SYSTEM'}",
