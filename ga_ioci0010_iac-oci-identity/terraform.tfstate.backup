              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-database-001', 'o-p-om2-id-common-001'/'99GISS.Cloud_DB_admin' to read work-requests in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exadb-001'))",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-database-001', 'o-p-om2-id-common-001'/'99GISS.Cloud_DB_admin' to manage data-safe-family in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exadb-001'))",
