        {
          "index_key": "PCY-STORAGE-KEY",
          "schema_version": 0,
          "attributes": {
            "ETag": "191782aa2e099a6389f4d3da783321de467474b2",
            "compartment_id": "ocid1.tenancy.oc19..aaaaaaaa4ftkyx3ao73kndo3mbltj6gtbf27mxbgpu65a33ipgo2wqyj4zba",
            "defined_tags": {
              "Oracle-Tags.CreatedBy": "default/jorge.e.torlaschi@accenture.com",
              "Oracle-Tags.CreatedOn": "2026-04-07T15:16:08.946Z"
            },
            "description": "Storage administration. Manage object, file and block storage in the Landing Zone. Destructive operations restricted.",
            "freeform_tags": {
              "ocilz-terraform-module": "iam-policies/0.3.4"
            },
            "id": "ocid1.policy.oc19..aaaaaaaamoie5vsiedi32odiku54acf7u2j53xdibgqr7jobqd7ntgqwxhla",
            "inactive_state": null,
            "lastUpdateETag": "191782aa2e099a6389f4d3da783321de467474b2",
            "name": "o-p-om2-pcy-stora-001",
            "policyHash": "9303c076df483acabaa865602d769a31",
            "state": "ACTIVE",
            "statements": [
              "allow group 'o-p-om2-id-common-001'/'99GISS.Cloud_Storage_admin' to manage object-family in compartment o-p-om2-cmp-land-001 where all{request.permission != 'OBJECT_DELETE', request.permission != 'BUCKET_DELETE'}",
              "allow group 'o-p-om2-id-common-001'/'99GISS.Cloud_Storage_admin' to manage file-family in compartment o-p-om2-cmp-land-001 where all{request.permission != 'FILE_SYSTEM_DELETE', request.permission != 'MOUNT_TARGET_DELETE', request.permission != 'EXPORT_SET_DELETE', request.permission != 'FILE_SYSTEM_DELETE_SNAPSHOT', request.permission != 'FILE_SYSTEM_NFSv3_UNEXPORT'}",
              "allow group 'o-p-om2-id-common-001'/'99GISS.Cloud_Storage_admin' to manage volume-family in compartment o-p-om2-cmp-land-001 where all{request.permission != 'VOLUME_DELETE', request.permission != 'VOLUME_BACKUP_DELETE', request.permission != 'BOOT_VOLUME_BACKUP_DELETE'}",
              "allow group 'o-p-om2-id-common-001'/'99GISS.Cloud_Storage_admin' to read all-resources in compartment o-p-om2-cmp-land-001",
              "allow group 'o-p-om2-id-common-001'/'99GISS.Cloud_Storage_admin' to use cloud-shell in tenancy"
            ],
            "time_created": "2026-04-07 15:16:08.956 +0000 UTC",
