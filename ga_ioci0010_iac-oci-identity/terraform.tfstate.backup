            },
            "description": "Example policy which allows the o-p-om2-grp-admi-infra-001 group users to manage the DB infra in all the environments and projects.",
            "freeform_tags": {
              "ocilz-terraform-module": "iam-policies/0.3.4"
            },
            "id": "ocid1.policy.oc19..aaaaaaaatvfyywb5ed64yslueu4wlpur4xnc2orplqrljaxsvwsatlszhqjq",
            "inactive_state": null,
            "lastUpdateETag": "0c189bcd0089c86b8869842d992e3eb229414e92",
            "name": "o-p-om2-pcy-einf-001",
            "policyHash": "71f96ec712511f129190d8ae706da976",
            "state": "ACTIVE",
            "statements": [
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-infra-001' to manage cloud-exadata-infrastructures in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exainfra-001'))",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-infra-001' to manage scheduling-policies in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exainfra-001'))",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-infra-001' to manage scheduling-windows in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exainfra-001'))",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-infra-001' to manage execution-windows in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exainfra-001'))",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-infra-001' to manage orm-stacks in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exainfra-001'))",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-infra-001' to manage orm-jobs in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exainfra-001'))",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-infra-001' to manage orm-config-source-providers in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exainfra-001'))",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-infra-001' to read audit-events in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exainfra-001'))",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-infra-001' to read work-requests in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exainfra-001'))",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-infra-001' to manage cloudevents-rules in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exainfra-001'))",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-infra-001' to manage cloud-vmclusters in compartment o-p-om2-cmp-land-001 where all{sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exainfra-001')), request.permission != 'CLOUD_VM_CLUSTER_UPDATE_GI_SOFTWARE', request.permission != 'CLOUD_VM_CLUSTER_UPDATE_EXADATA_STORAGE'}",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-infra-001' to use dbServers in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exainfra-001'))",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-infra-001' to manage dbnode-console-connection in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exainfra-001'))",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-infra-001' to manage dbnode-console-history in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exainfra-001'))",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-infra-001' to manage cloud-autonomous-vmclusters in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exainfra-001'))",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-infra-001' to use subnets in compartment o-p-om2-cmp-land-001  where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-network-001'))",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-infra-001' to use vnics in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-network-001'))",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-infra-001' to manage db-nodes in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exainfra-001'))",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-infra-001' to use database-software-images in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-network-001'))"
