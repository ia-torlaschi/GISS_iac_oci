              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-database-001' to manage autonomous-databases in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exadb-001'))",
