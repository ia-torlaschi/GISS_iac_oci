            },
            "description": "Example policy which allows the o-p-om2-grp-admi-database-001 group users to manage databases in all the environments and projects.",
            "freeform_tags": {
              "ocilz-terraform-module": "iam-policies/0.3.3\n"
            },
            "id": "ocid1.policy.oc19..aaaaaaaa6mkjpk4romgxowgqgwkzobk67ysco6bdmkfwcfotk6uy5w6fcwlq",
            "inactive_state": null,
            "lastUpdateETag": "c1aec21394fc2c3c7c7ea8af0df3769667a84bd4",
            "name": "o-p-om2-pcy-edb-001",
            "policyHash": "135bfe713093193469f48d45db269945",
            "state": "ACTIVE",
            "statements": [
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-database-001' to manage orm-stacks in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exadb-001'))",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-database-001' to manage orm-jobs in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exadb-001'))",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-database-001' to manage orm-config-source-providers in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exadb-001'))",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-database-001' to read audit-events in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exadb-001'))",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-database-001' to read work-requests in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exadb-001'))",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-database-001' to manage data-safe-family in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exadb-001'))",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-database-001' to manage cloudevents-rules in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exadb-001'))",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-database-001' to use cloud-exadata-infrastructures in compartment o-p-om2-cmp-land-001 where all{sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exadb-001')), request.operation != 'ChangeCloudExadataInfrastructureCompartment', request.operation != 'AddStorageCapacityCloudExadataInfrastructure'}",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-database-001' to use cloud-vmclusters in compartment o-p-om2-cmp-land-001 where all{sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exadb-001')), request.permission != 'CLOUD_VM_CLUSTER_UPDATE_SSH_KEY', request.permission != 'CLOUD_VM_CLUSTER_UPDATE_CPU', request.permission != 'CLOUD_VM_CLUSTER_UPDATE_MEMORY', request.permission !='CLOUD_VM_CLUSTER_UPDATE_LOCAL_STORAGE', request.permission != 'CLOUD_VM_CLUSTER_UPDATE_FILE_SYSTEM'}",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-database-001' to manage backups in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exadb-001'))",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-database-001' to manage database-software-image in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exadb-001'))",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-database-001' to manage db-homes in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exadb-001'))",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-database-001' to manage databases in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exadb-001'))",
