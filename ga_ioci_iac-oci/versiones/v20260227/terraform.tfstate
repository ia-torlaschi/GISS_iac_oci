        {
          "index_key": "PCY-NETWORK-ADMIN-KEY",
          "schema_version": 0,
          "attributes": {
            "ETag": "890906110d587f66e3877dc6c800192d36521a68",
            "compartment_id": "ocid1.compartment.oc19..aaaaaaaay3khgdz6euxlks7pja7uxv6d4czkxlp75ynqgyjkrjylf3tgsubq",
