alse\n                                    },\n                                    {\n                                        \"description\"                     : \"ICMP type 8 (Echo)\",\n                                        \"src\"                             : \"10.0.0.0/21\",\n                                        \"src_type\"                        : \"CIDR_BLOCK\",\n                                        \"protocol\"                        : \"ICMP\",\n                                        \"icmp_type\"                       : 8,\n                                        \"icmp_code\"                       : 0,\n                                        \"stateless\"                       : false\n                                    },\n                                    {\n                                        \"description\"                     : \"EXAMPLE: Allow inbound traffic from the Bastion Service private endpoint IP address\",\n                                        \"src\"                             : \"10.0.2.123/32\",\n                                        \"src_type\"                        : \"CIDR_BLOCK\",\n                                        \"dst_port_max\"                    : 22,\n                                        \"dst_port_min\"                    : 22,\n                                        \"protocol\"                        : \"TCP\",\n                                        \"stateless\"                       : false\n                                    }\n                                ]\n                            }\n                        },\n\n                        \"network_security_groups\": {\n                            \"NSG-VLL-LZ-HUB-LB-KEY\": {\n                                \"display_name\"                            : \"o-p-om2-nsg-hublb-001\",\n\n                                \"egress_rules\": {\n                                    \"anywhere\": {\n                                        \