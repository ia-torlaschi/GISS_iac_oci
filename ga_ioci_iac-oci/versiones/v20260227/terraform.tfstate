            "state": "ACTIVE",
            "statements": [
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-infra-001','o-p-om2-id-common-001'/'o-p-om2-grp-admi-database-001' to use cloud-shell in tenancy",
