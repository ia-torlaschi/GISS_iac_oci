k-001'))\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-security-001' to manage private-ips in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-network-001'))\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-security-001' to read keys in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-network-001'))\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-security-001' to manage operator-control-family in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-security-001'))\"\n                ]\n            },\n\n            \"PCY-GLOBALSERV-ADMIN-KEY\": {\n                \"name\"                                         : \"o-p-om2-pcy-globalserv-001\",\n                \"description\"                                  : \"Allow o-p-om2-grp-admi-globresou-001 group users to manage gloabal service, as cloud guard\",\n                \"compartment_id\"                               : \"TENANCY-ROOT\",\n\n                \"statements\": [\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-globalserv-001' to manage cloudevents-rules in tenancy\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-globalserv-001' to manage cloud-guard-family in tenancy\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-globalserv-001' to read tenancies in tenancy\"\n                ]\n            },\n\n            \"PCY-SERVICES-ADMIN-KEY\": {\n                \"name\"                                         : \"o-p-om2-pcy-srva-001\",\n                \"description\"                                  : \"Policy for all supported services in the tenancy.\",\n                \"compartment_id\"                               : \"TENANCY-ROOT\",\n\n                \"statements\": [\n                    \"allow service cloudguard to manage cloudevents-rules in tenancy where target.rule.type='managed'\",\n                    \"allow service cloudguard to read tenancies in tenancy\",\n                    \"allow service cloudguard to read all-resources in tenancy\",\n                    \"allow service cloudguard to use network-security-groups in tenancy\",\n                    \"allow any-user to { WLP_BOM_READ, WLP_CONFIG_READ } in tenancy where all { request.principal.id = target.agent.id, request.principal.type = 'workloadprotectionagent'}\",\n                    \"endorse any-user to { WLP_LOG_CREATE, WLP_METRICS_CREATE, WLP_ADHOC_QUERY_READ, WLP_ADHOC_RESULTS_CREATE } in any-tenancy where all { request.principal.id = target.agent.id, request.principal.type = 'workloadprotectionagent' }\",\n                    \"allow service vulnerability-scanning-service to manage instances in tenancy\",\n                    \"allow service vulnerability-scanning-service to read compartments in tenancy\",\n                    \"allow service vulnerability-scanning-service to read repos in tenancy\",\n                    \"allow service vulnerability-scanning-service to read vnics in tenancy\",\n                    \"allow service vulnerability-scanning-service to read vnic-attachments in tenancy\",\n                    \"allow service osms to read instances in tenancy\",\n                    \"allow service blockstorage, oke, streaming to use keys in tenancy\"\n                ]\n            },\n\n            \"PCY-LZ-PLATFORM-EXACS-GENERIC-ADMIN-KEY\": {\n                \"name\"                                              : \"o-p-om2-pcy-eadm-001\",\n                \"description\"                                       : \"Policy which allows the groups o-p-om2-grp-admi-infra-001 and o-p-om2-grp-admi-database-001 to have shared privilegies in all exacs compartments\",\n                \"compartment_id\"                                    : \"TENANCY-ROOT\",\n                \"statements\": [\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-infra-001','o-p-om2-id-common-001'/'o-p-om2-grp-admi-database-001' to use cloud-shell in tenancy\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-infra-001','o-p-om2-id-common-001'/'o-p-om2-grp-admi-database-001' to read compartments in tenancy\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-infra-001','o-p-om2-id-common-001'/'o-p-om2-grp-admi-database-001' to read all-resources in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exa-001'))\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-infra-001','o-p-om2-id-common-001'/'o-p-om2-grp-admi-database-001' to manage alarms in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exa-001'))\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-infra-001','o-p-om2-id-common-001'/'o-p-om2-grp-admi-database-001' to manage metrics in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exa-001'))\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-infra-001','o-p-om2-id-common-001'/'o-p-om2-grp-admi-database-001' to read audit-events in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exa-001'))\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-infra-001','o-p-om2-id-common-001'/'o-p-om2-grp-admi-database-001' to read work-requests in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exa-001'))\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-infra-001','o-p-om2-id-common-001'/'o-p-om2-grp-admi-database-001' to manage cloudevents-rules in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exa-001'))\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-infra-001','o-p-om2-id-common-001'/'o-p-om2-grp-admi-database-001' to manage ons-family in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exa-001'))\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-infra-001','o-p-om2-id-common-001'/'o-p-om2-grp-admi-database-001' to manage alarms in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exa-001'))\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-infra-001','o-p-om2-id-common-001'/'o-p-om2-grp-admi-database-001' to manage metrics in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exa-001'))\"\n\n                ]\n            },\n\n            \"PCY-LZ-PLATFORM-EXACS-DB-ADMIN-KEY\": {\n                \"name\"                                              : \"o-p-om2-pcy-edb-001\",\n                \"description\"                                       : \"Example policy which allows the o-p-om2-grp-admi-database-001 group users to manage databases in all the environments and projects.\",\n                \"compartment_id\"                                    : \"CMP-LANDINGZONE-KEY\",\n                \"statements\": [\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-database-001' to manage orm-stacks in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exadb-001'))\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-database-001' to manage orm-jobs in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exadb-001'))\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-database-001' to manage orm-config-source-providers in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exadb-001'))\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-database-001' to read audit-events in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exadb-001'))\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-database-001' to read work-requests in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exadb-001'))\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-database-001' to manage data-safe-family in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exadb-001'))\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-database-001' to manage cloudevents-rules in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exadb-001'))\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-database-001' to use cloud-exadata-infrastructures in compartment o-p-om2-cmp-land-001 where all{sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exadb-001')), request.operation != 'ChangeCloudExadataInfrastructureCompartment', request.operation != 'AddStorageCapacityCloudExadataInfrastructure'}\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-database-001' to use cloud-vmclusters in compartment o-p-om2-cmp-land-001 where all{sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exadb-001')), request.permission != 'CLOUD_VM_CLUSTER_UPDATE_SSH_KEY', request.permission != 'CLOUD_VM_CLUSTER_UPDATE_CPU', request.permission != 'CLOUD_VM_CLUSTER_UPDATE_MEMORY', request.permission !='CLOUD_VM_CLUSTER_UPDATE_LOCAL_STORAGE', request.permission != 'CLOUD_VM_CLUSTER_UPDATE_FILE_SYSTEM'}\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-database-001' to manage backups in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exadb-001'))\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-database-001' to manage database-software-image in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exadb-001'))\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-database-001' to manage db-homes in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-exadb-001'))\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-