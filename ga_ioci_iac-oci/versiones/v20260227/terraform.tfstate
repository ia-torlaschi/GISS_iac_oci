            "description": "Policy for all supported services in the tenancy.",
            "freeform_tags": {
              "ocilz-terraform-module": "iam-policies/0.3.3\n"
            },
            "id": "ocid1.policy.oc19..aaaaaaaad44w3wpxupoezmu7uptg4zhpkovm7253gzmxle5qxavdxulmy6ia",
