            "base64_encode_content": false,
            "bucket": "bucket-lz-20260227",
            "cache_control": null,
            "content": "{\n    \"compartments_configuration\": {\n        \"enable_delete\"                                        : \"true\",\n\n        \"compartments\": {\n            \"CMP-LANDINGZONE-KEY\": {\n                \"name\"                                         : \"o-p-om2-cmp-land-001\",\n                \"description\"                                  : \"Enclosing Production Landing Zone Compartment\",\n\n                \"children\": {\n                    \"CMP-LZ-NETWORK-KEY\": {\n                        \"name\"                                 : \"o-p-om2-cmp-network-001\",\n                        \"description\"                          : \"Shared Network Compartment\",\n\n                        \"defined_tags\": {\n                            \"o-p-om2-tagns-name-001.o-p-om2-tag-role-001\"        : \"o-p-om2-tag-role-network-001\"\n                        }\n                    },\n\n                    \"CMP-LZ-PLATFORM-KEY\": {\n                        \"name\"                                 : \"o-p-om2-cmp-platform-001\",\n                        \"description\"                          : \"Shared Platform Compartment\",\n\n                        \"children\": {\n                                \"CMP-LZ-EXACS-KEY\": {\n                                    \"name\"                                      : \"o-p-om2-cmp-exacs-001\",\n                                    \"description\"                               : \"Shared exacs Platform\",\n                                    \"defined_tags\": {\n                                                \"o-p-om2-tagns-name-001.o-p-om2-tag-role-001\"          : \"o-p-om2-tag-role-exa-001\"\n                                    },\n                                    \"children\": {\n                                            \"CMP-LZ-EXACS-DB-KEY\": {\n                                                \"name\"                         : \"o-p-om2-cmp-exacsdb-001\",\n                                                \"description\"                  : \"Shared exacs Platform, db compartment\",\n                                                 \"defined_tags\": {\n                                                                \"o-p-om2-tagns-name-001.o-p-om2-tag-role-001\"        : \"o-p-om2-tag-role-exadb-001\"\n                                                                }\n                                            },\n                                            \"CMP-LZ-EXACS-INFRA-KEY\": {\n                                                \"name\"                         : \"o-p-om2-cmp-exacsinfra-001\",\n                                                \"description\"                  : \"Shared exacs Platform, infra compartment\",\n                                                 \"defined_tags\": {\n                                                                \"o-p-om2-tagns-name-001.o-p-om2-tag-role-001\"        : \"o-p-om2-tag-role-exainfra-001\"\n                                                                }\n                                            }\n                                    }\n                                },\n                                \"CMP-LZ-LOGGING-KEY\": {\n                                    \"name\"                         : \"o-p-om2-cmp-logg-001\",\n                                    \"description\"                  : \"Shared Logging Platform\"\n                                },\n                                \"CMP-LZ-DEVOPS-KEY\": {\n                                    \"name\"                         : \"o-p-om2-cmp-devop-001\",\n                                    \"description\"                  : \"Shared devops Platform\"\n                                \n                            }\n                         }\n                    },     \n\n                    \"CMP-LZ-CDINSS-KEY\": {\n                        \"name\"                                 : \"o-p-om2-cmp-cdin-core-001\",\n                        \"description\"                          : \"Coretech Entity Environment Compartment\",\n\n                        \"children\": {\n                        \"CMP-LZ-CDINSS-PROD-KEY\": {\n                            \"name\"                                 : \"o-p-om2-cmp-cdin-001\",\n                            \"description\"                          : \"Production Environment Compartment\",\n\n                            \"children\": {\n                                \"CMP-LZ-CDINSS-PROD-NETWORK-KEY\": {\n                                    \"name\"                         : \"o-p-om2-cmp-cdin-network-001\",\n                                    \"description\"                  : \"Prod Workload Environment, Common Network Compartment\",\n\n                                    \"defined_tags\": {\n                                        \"o-p-om2-tagns-name-001.o-p-om2-tag-role-001\": \"o-p-om2-tag-role-network-001\"\n                                    }\n                                },\n\n                                \"CMP-LZ-CDINSS-PROD-PLATFORM-KEY\": {\n                                    \"name\"                         : \"o-p-om2-cmp-cdin-platform-001\",\n                                    \"description\"                  : \"Production Workload Environment, Common Platform Compartment\"\n                                },\n\n                                \"CMP-LZ-CDINSS-PROD-PROJECTS-KEY\": {\n                                    \"name\"                         : \"o-p-om2-cmp-cdin-projects-001\",\n                                    \"description\"                  : \"Production Workload Environment, Common Projects Compartment\"\n\n                                },\n\n                                \"CMP-LZ-CDINSS-PROD-SECURITY-KEY\": {\n                                    \"name\"                         : \"o-p-om2-cmp-cdin-security-001\",\n                                    \"description\"                  : \"Production Workload Environment, Common Security Compartment\",\n\n                                    \"defined_tags\": {\n                                        \"o-p-om2-tagns-name-001.o-p-om2-tag-role-001\": \"o-p-om2-tag-role-security-001\"\n                                    }\n                                }\n                            }\n                        },\n                        \"CMP-LZ-CDINSS-NPR-KEY\": {\n                            \"name\"                                 : \"o-np-om2-cmp-cdin-001\",\n                            \"description\"                          : \"Non Production Environment Compartment\",\n\n                            \"children\": {\n                                \"CMP-LZ-CDINSS-NPR-NETWORK-KEY\": {\n                                    \"name\"                         : \"o-np-om2-cmp-cdin-network-001\",\n                                    \"description\"                  : \"Non Production Workload Environment, Common Network Compartment\",\n\n                                    \"defined_tags\": {\n                                        \"o-p-om2-tagns-name-001.o-p-om2-tag-role-001\": \"o-p-om2-tag-role-network-001\"\n                                    }\n                                },\n\n                                \"CMP-LZ-CDINSS-NPR-PLATFORM-KEY\": {\n                                    \"name\"                         : \"o-np-om2-cmp-cdin-platform-001\",\n                                    \"description\"                  : \"Non Production Workload Environment, Common Platform Compartment\"\n                    \n                                },\n\n                                \"CMP-LZ-CDINSS-NPR-PROJECTS-KEY\": {\n                                    \"name\"                         : \"o-np-om2-cmp-cdin-projects-001\",\n                                    \"description\"                  : \"Non Production Workload Environment, Common Projects Compartment\"\n\n                                },\n\n                                \"CMP-LZ-CDINSS-NPR-SECURITY-KEY\": {\n                                    \"name\"                         : \"o-np-om2-cmp-cdin-security-001\",\n                                    \"description\"                  : \"Non Production Workload Environment, Common Security Compartment\",\n\n                                    \"defined_tags\": {\n                                        \"o-p-om2-tagns-name-001.o-p-om2-tag-role-001\": \"o-p-om2-tag-role-security-001\"\n                                    }\n                                }\n                            }\n                        }\n                        }\n                    },\n\n                    \"CMP-LZ-SECURITY-KEY\": {\n                            \"name\"                                 : \"o-p-om2-cmp-security-001\",\n                            \"description\"                          : \"Shared Security Compartment\",\n\n                            \"defined_tags\": {\n                                \"o-p-om2-tagns-name-001.o-p-om2-tag-role-001\"        : \"o-p-om2-tag-role-security-001\"\n                            }\n                    }\n                }\n                }\n            }\n    },\n\n    \"identity_domain_groups_configuration\": {\n        \"default_identity_domain_id\"                           : \"COMMON-DOMAIN\",\n\n        \"groups\": {\n            \"GRP-AUDITORS-ADMIN-KEY\": {\n                \"name\"                                         : \"o-p-om2-grp-admi-auditors-001\", \n                \"description\"                                  : \"Tenancy global read access group(for security auditing or health checks).\"\n            },\n\n            \"GRP-COST-ADMIN-KEY\": {\n                \"name\"                                         : \"o-p-om2-grp-admi-costs-001\",\n                \"description\"                                  : \"Tenancy global cost control group.\"\n            },\n\n            \"GRP-IAM-ADMIN-KEY\": {\n                \"name\"                                         : \"o-p-om2-grp-admi-iam-001\",\n                \"description\"                                  : \"Tenancy global Identity and access management administrator group.\"\n            },\n\n            \"GRP-NETWORK-ADMIN-KEY\": {\n                \"name\"                                         : \"o-p-om2-grp-admi-network-001\",\n                \"description\"                                  : \"Shared network administration group, including common OE network elements.\"\n            },\n\n            \"GRP-SECURITY-ADMIN-KEY\": {\n                \"name\"                                         : \"o-p-om2-grp-admi-security-001\",\n                \"description\"                                  : \"Shared security administration group, including common OE network elements.\"\n            },\n\n            \"GRP-GLOBALSERV-ADMIN-KEY\": {\n                \"name\"                                         : \"o-p-om2-grp-admi-globalserv-001\",\n                \"description\"                                  : \"Tenancy Administrators for global services, as Cloud Guard.\"\n            },\n\n            \"GRP-LZ-INFRA-ADMINS\": { \n                \"name\"                                          : \"o-p-om2-grp-admi-infra-001\",\n                \"description\"                                   : \"Global exacs administration, Infra Team group\"\n            },\n            \"GRP-LZ-DB-ADMINS\": { \n                \"name\"                                          : \"o-p-om2-grp-admi-database-001\",\n                \"description\"                                   : \"Global exacs administration, DBA Team group\"\n            }\n\n            \n\n        }       \n    },\n\n    \"identity_domains_configuration\": {\n        \"default_compartment_id\"                               : null,\n        \"default_defined_tags\"                                 : null,\n        \"default_freeform_tags\"                                : null,\n\n        \"identity_domains\": {\n            \"COMMON-DOMAIN\": {\n                \"display_name\"                                 : \"o-p-om2-id-common-001\",\n                \"description\"                                  : \"One-OE LZ common Identity Domain\",\n                \"compartment_id\"                               : null,\n                \"admin_email\"                                  : null,\n                \"admin_first_name\"                             : null,\n                \"admin_last_name\"                              : null,\n                \"admin_user_name\"                              : null,\n                \"allow_signing_cert_public_access\"             : false,\n                \"home_region\"                                  : null,\n                \"is_hidden_on_login\"                           : false,\n                \"is_notification_bypassed\"                     : false,\n                \"is_primary_email_required\"                    : false,\n                \"license_type\"                                 : \"free\",\n                \"replica_region\"                               : null\n            }\n        }\n    },\n\n    \"policies_configuration\": {\n        \"enable_cis_benchmark_checks\"                          : \"false\",\n\n        \"supplied_policies\": {\n            \"PCY-AUDITING-ADMIN-KEY\": {\n                \"name\"                                         : \"o-p-om2-pcy-auda-001\",\n                \"description\"                                  : \"Allow o-p-om2-grp-admi-auditors-001 group users to read all the resources in the tenancy.\",\n                \"compartment_id\"                               : \"TENANCY-ROOT\",\n\n                \"statements\": [\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-auditors-001' to inspect all-resources in tenancy\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-auditors-001' to read instances in tenancy\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-auditors-001' to read load-balancers in tenancy\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-auditors-001' to read buckets in tenancy\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-auditors-001' to read nat-gateways in tenancy\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-auditors-001' to read public-ips in tenancy\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-auditors-001' to read file-family in tenancy\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-auditors-001' to read instance-configurations in tenancy\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-auditors-001' to read network-security-groups in tenancy\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-auditors-001' to read resource-availability in tenancy\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-auditors-001' to read audit-events in tenancy\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-auditors-001' to read users in tenancy\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-auditors-001' to use cloud-shell in tenancy\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-auditors-001' to read vss-family in tenancy\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-auditors-001' to read usage-budgets in tenancy\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-auditors-001' to read usage-reports in tenancy\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-auditors-001' to read data-safe-family in tenancy\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-auditors-001' to read vaults in tenancy\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-auditors-001' to read keys in tenancy\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-auditors-001' to read tag-namespaces in tenancy\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-auditors-001' to read serviceconnectors in tenancy\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-auditors-001' to use ons-family in tenancy where any {request.operation!=/Create*/, request.operation!=/Update*/, request.operation!=/Delete*/, request.operation!=/Change*/}\"\n                ]\n            },\n\n            \"PCY-COST-ADMIN-KEY\": {\n                \"name\"                                         : \"o-p-om2-pcy-costs-001\",\n                \"description\"                                  : \"Allow o-p-om2-grp-admi-costs-001 group users to manage all budget resources in the tenancy.\",\n                \"compartment_id\"                               : \"TENANCY-ROOT\",\n\n                \"statements\": [\n                    \"define tenancy usage-report as ocid1.tenancy.oc1..aaaaaaaaned4fkpkisbwjlr56u7cj63lf3wffbilvqknstgtvzub7vhqkggq\",\n                    \"endorse group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-costs-001' to read objects in tenancy usage-report\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-costs-001' to manage usage-report in tenancy\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-costs-001' to manage usage-budgets in tenancy\"\n                ]\n            },\n\n            \"PCY-GENERIC-ADMIN-KEY\": {\n                \"name\"                                         : \"o-p-om2-pcy-gadm-001\",\n                \"description\"                                  : \"Allow defined groups to use generic services.\",\n                \"compartment_id\"                               : \"TENANCY-ROOT\",\n\n                \"statements\": [\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-iam-001', 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-auditors-001', 'o-p-om2-id-common-001'/'o-p-om2-grp-seca-001', 'o-p-om2-id-common-001'/'o-p-om2-grp-neta-001' to use cloud-shell in tenancy\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-iam-001', 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-auditors-001', 'o-p-om2-id-common-001'/'o-p-om2-grp-seca-001', 'o-p-om2-id-common-001'/'o-p-om2-grp-neta-001' to use cloud-shell-public-network in tenancy\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-iam-001', 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-auditors-001', 'o-p-om2-id-common-001'/'o-p-om2-grp-seca-001', 'o-p-om2-id-common-001'/'o-p-om2-grp-neta-001' to read usage-budgets in tenancy\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-iam-001', 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-auditors-001', 'o-p-om2-id-common-001'/'o-p-om2-grp-seca-001', 'o-p-om2-id-common-001'/'o-p-om2-grp-neta-001' to read usage-reports in tenancy\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-iam-001', 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-auditors-001', 'o-p-om2-id-common-001'/'o-p-om2-grp-seca-001', 'o-p-om2-id-common-001'/'o-p-om2-grp-neta-001' to read objectstorage-namespaces in tenancy\",\n                    \"allow any-user to inspect tag-namespaces in tenancy where target.tag-namespace.name='o-p-om2-tagns-name-001'\"\n                ]\n            },\n\n            \"PCY-IAM-ADMIN-KEY\": {\n                \"name\"                                         : \"o-p-om2-pcy-iam-001\",\n                \"description\"                                  : \"Allow o-p-om2-grp-admi-iam-001 group users to manage IAM resources in the tenancy.\",\n                \"compartment_id\"                               : \"TENANCY-ROOT\",\n\n                \"statements\": [\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-iam-001' to manage policies in tenancy\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-iam-001' to manage users in tenancy\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-iam-001' to inspect groups in tenancy\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-iam-001' to manage groups in tenancy where all {target.group.name != 'Administrators'}\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-iam-001' to manage identity-providers in tenancy\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-iam-001' to manage dynamic-groups in tenancy\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-iam-001' to manage authentication-policies in tenancy\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-iam-001' to manage network-sources in tenancy\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-iam-001' to manage quota in tenancy\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-iam-001' to manage tag-defaults in tenancy\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-iam-001' to manage tag-namespaces in tenancy\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-iam-001' to manage orm-jobs in tenancy\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-iam-001' to manage orm-config-source-providers in tenancy\"\n                ]\n            },\n\n            \"PCY-NETWORK-ADMIN-KEY\": {\n                \"name\"                                         : \"o-p-om2-pcy-nadm-001\",\n                \"description\"                                  : \"Allow o-p-om2-grp-neta-001 group users to manage all network resources in the child compartments of o-p-om2-cmp-001 with the matching tags.\",\n                \"compartment_id\"                               : \"CMP-LANDINGZONE-KEY\",\n\n                \"statements\": [\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-neta-001' to read all-resources in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-network-001'))\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-neta-001' to manage virtual-network-family in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-network-001'))\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-neta-001' to manage dns in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-network-001'))\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-neta-001' to manage load-balancers in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-network-001'))\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-neta-001' to manage alarms in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-network-001'))\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-neta-001' to manage metrics in compartment o-p-om2-cmp-land-001 where sets-intersect(target.resource.compartment.tag.o-p-om2-tagns-name-001.o-p-om2-tag-role-001, ('o-p-om2-tag-role-network-001'))\",\n                    \"allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-neta-001