        {
          "index_key": "PCY-AUDITING-ADMIN-KEY",
          "schema_version": 0,
          "attributes": {
            "ETag": "ba303a8bda621be40d0fb6036c5b5b87abdec337",
            "compartment_id": "ocid1.tenancy.oc19..aaaaaaaa4ftkyx3ao73kndo3mbltj6gtbf27mxbgpu65a33ipgo2wqyj4zba",
            "defined_tags": {
              "Oracle-Tags.CreatedBy": "default/jorge.e.torlaschi@accenture.com",
              "Oracle-Tags.CreatedOn": "2026-03-02T14:48:56.825Z"
            },
            "description": "Allow o-p-om2-grp-admi-auditors-001 group users to read all the resources in the tenancy.",
            "freeform_tags": {
              "ocilz-terraform-module": "iam-policies/0.3.3\n"
            },
            "id": "ocid1.policy.oc19..aaaaaaaa2xercruasfu3wacdfwdyl7ovqyswyxnmrtzlqbsfji6ncv4xwf6q",
            "inactive_state": null,
            "lastUpdateETag": "ba303a8bda621be40d0fb6036c5b5b87abdec337",
            "name": "o-p-om2-pcy-auda-001",
            "policyHash": "e730b8858c9ae7d01d367098d53dc7b6",
            "state": "ACTIVE",
            "statements": [
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-auditors-001' to inspect all-resources in tenancy",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-auditors-001' to read instances in tenancy",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-auditors-001' to read load-balancers in tenancy",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-auditors-001' to read buckets in tenancy",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-auditors-001' to read nat-gateways in tenancy",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-auditors-001' to read public-ips in tenancy",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-auditors-001' to read file-family in tenancy",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-auditors-001' to read instance-configurations in tenancy",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-auditors-001' to read network-security-groups in tenancy",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-auditors-001' to read resource-availability in tenancy",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-auditors-001' to read audit-events in tenancy",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-auditors-001' to read users in tenancy",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-auditors-001' to use cloud-shell in tenancy",
              "allow group 'o-p-om2-id-common-001'/'o-p-om2-grp-admi-auditors-001' to read vss-family in tenancy",
