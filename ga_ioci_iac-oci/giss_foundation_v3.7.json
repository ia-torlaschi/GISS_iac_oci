            "is_retired": false
          },
          "TAG-GOV-OPERATIONAL-OWNER-KEY": {
            "name": "operational-owner",
            "description": "Empresa cliente o equipo que gestiona los recursos. Valor: correo corporativo del responsable operacional.",
            "is_cost_tracking": false,
            "is_retired": false
          },
          "TAG-GOV-DEPARTMENT-KEY": {
            "name": "department",
