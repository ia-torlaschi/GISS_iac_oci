            "is_cost_tracking": true,
            "is_retired": false
          },
          "TAG-GOV-APPLICATION-NAME-KEY": {
            "name": "application-name",
            "description": "Nombre legible de la aplicacion asociada al recurso.",
            "is_cost_tracking": false,
            "is_retired": false
          },
          "TAG-GOV-NAME-KEY": {
            "name": "name",
            "description": "Nombre del recurso. Debe coincidir con el display_name del recurso OCI. Habilitado para analisis de costes por recurso individual.",
            "is_cost_tracking": true,
            "is_retired": false
          },
          "TAG-GOV-ENVIRONMENT-KEY": {
            "name": "environment",
            "description": "Entorno del recurso. Se infiere del prefijo de nomenclatura: o-p- = pro, o-d- = dev. Habilitado para comparativa de costes entre entornos.",
            "is_cost_tracking": true,
            "is_retired": false,
            "validator": {
              "validator_type": "ENUM",
              "values": [
                "dev",
                "pre",
                "pro",
                "int",
                "qa",
                "cer"
              ]
            }
          },
          "TAG-GOV-IAC-KEY": {
            "name": "iac",
            "description": "Indica el mecanismo mediante el cual fue generado el recurso. Valor automatico: terraform para todos los recursos desplegados por este repositorio.",
            "is_cost_tracking": false,
            "is_retired": false,
            "validator": {
              "validator_type": "ENUM",
              "values": [
                "terraform",
                "manual",
                "cli"
              ]
            }
          },
          "TAG-GOV-BUSINESS-CRITICALITY-KEY": {
            "name": "business-criticality",
            "description": "Criticidad de negocio del recurso. Determina la politica de parcheo, backup y actualizacion aplicable.",
            "is_cost_tracking": false,
            "is_retired": false,
            "validator": {
              "validator_type": "ENUM",
              "values": [
                "critico",
                "alto",
                "medio",
                "bajo"
              ]
            }
          }
        }
      },
      "TAGNS-LZ-ENS-KEY": {
